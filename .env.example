# Telegram notifier credentials.
# Copy this file to ".env" and fill in your own values. NEVER commit the real
# .env file or write these tokens into source code.

# Bot token from @BotFather (looks like 123456789:ABCdefGhIJKlmNoPQRstuVWxyz).
TELEGRAM_BOT_TOKEN=

# Target chat id. Get it by messaging your bot, then visiting
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates and reading "chat":{"id":...}.
TELEGRAM_CHAT_ID=
